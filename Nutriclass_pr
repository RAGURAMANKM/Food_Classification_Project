print("\nModel Evaluation Completed Successfully")

# ==========================================
# Food Prediction System
# ==========================================

print("\n====================================")
print("Food Prediction System")
print("====================================")

loaded_model = joblib.load(
    "best_food_classifier.pkl"
)

loaded_scaler = joblib.load(
    "scaler.pkl"
)

loaded_pca = joblib.load(
    "pca.pkl"
)

loaded_label_encoder = joblib.load(
    "label_encoder.pkl"
)

# ==========================================
# User Input
# ==========================================

input_data = {}

input_data["calories"] = float(input("Calories : "))
input_data["protein"] = float(input("Protein : "))
input_data["fat"] = float(input("Fat : "))
input_data["carbs"] = float(input("Carbohydrates : "))
input_data["sugar"] = float(input("Sugar : "))
input_data["fiber"] = float(input("Fiber : "))
input_data["sodium"] = float(input("Sodium : "))
input_data["cholesterol"] = float(input("Cholesterol : "))
input_data["glycemic_index"] = float(input("Glycemic Index : "))
input_data["water_content"] = float(input("Water Content : "))
input_data["serving_size"] = float(input("Serving Size : "))

meal_type = input("Meal Type : ")

preparation_method = input(
    "Preparation Method : "
)

is_vegan = input(
    "Is Vegan (Yes/No) : "
)

is_gluten_free = input(
    "Is Gluten Free (Yes/No) : "
)

# ==========================================
# DataFrame
# ==========================================

input_df = pd.DataFrame(
    [input_data]
)

# ==========================================
# Create Missing Dummy Columns
# ==========================================

for column in X.columns:

    if column not in input_df.columns:

        input_df[column] = 0

# ==========================================
# Meal Type
# ==========================================

meal_column = "meal_type_" + meal_type

if meal_column in input_df.columns:

    input_df[meal_column] = 1

# ==========================================
# Preparation Method
# ==========================================

prep_column = (
    "preparation_method_"
    + preparation_method
)

if prep_column in input_df.columns:

    input_df[prep_column] = 1

# ==========================================
# Vegan
# ==========================================

if is_vegan.lower() == "yes":

    vegan_column = "is_vegan_True"

    if vegan_column in input_df.columns:

        input_df[vegan_column] = 1

# ==========================================
# Gluten Free
# ==========================================

if is_gluten_free.lower() == "yes":

    gluten_column = "is_gluten_free_True"

    if gluten_column in input_df.columns:

        input_df[gluten_column] = 1

# ==========================================
# Arrange Columns
# ==========================================

input_df = input_df[
    X.columns
]

# ==========================================
# Standard Scaling
# ==========================================

input_df.loc[:, numeric_columns] = loaded_scaler.transform(
    input_df[numeric_columns]
)

# ==========================================
# PCA
# ==========================================

input_pca = loaded_pca.transform(
    input_df
)

# ==========================================
# Prediction
# ==========================================

prediction = loaded_model.predict(
    input_pca
)

predicted_food = loaded_label_encoder.inverse_transform(
    prediction
)

print("\n====================================")
print("Predicted Food Name")
print("====================================")

print(predicted_food[0])

print("\nFood Prediction Completed Successfully")